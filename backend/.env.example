# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="OptimalFuel"
APP_ENV="development"          # development | production
APP_HOST="0.0.0.0"
APP_PORT=8000
SECRET_KEY="change-me-to-a-long-random-string"   # openssl rand -hex 32

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, perfect for personal use)
DATABASE_URL="sqlite+aiosqlite:///./optimalfuel.db"

# Uncomment to switch to PostgreSQL later:
# DATABASE_URL="postgresql+asyncpg://user:password@localhost/optimalfuel"

# ─── Polar Accesslink ─────────────────────────────────────────────────────────
# Register at: https://admin.polaraccesslink.com
POLAR_CLIENT_ID=""
POLAR_CLIENT_SECRET=""
POLAR_REDIRECT_URI="http://localhost:8000/api/v1/auth/polar/callback"

# Stored after OAuth — do not fill manually
POLAR_ACCESS_TOKEN=""
POLAR_TOKEN_EXPIRES_AT=""
POLAR_USER_ID=""

# ─── Strava ───────────────────────────────────────────────────────────────────
# Register at: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_REDIRECT_URI="http://localhost:8000/api/v1/auth/strava/callback"

# Stored after OAuth — do not fill manually
STRAVA_ACCESS_TOKEN=""
STRAVA_REFRESH_TOKEN=""
STRAVA_TOKEN_EXPIRES_AT=""
STRAVA_ATHLETE_ID=""

# ─── Nutrition ────────────────────────────────────────────────────────────────
# Optional: Edamam food database API (free tier is enough)
# Register at: https://developer.edamam.com
EDAMAM_APP_ID=""
EDAMAM_APP_KEY=""

# ─── Scheduler ────────────────────────────────────────────────────────────────
# How often to sync data from Polar and Strava (minutes)
SYNC_INTERVAL_MINUTES=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
